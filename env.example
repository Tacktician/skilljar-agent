# ──────────────────────────────────────────────
# REQUIRED (always)
# ──────────────────────────────────────────────

# SkillJar API key — authenticates against your SkillJar instance
# Find at: SkillJar Dashboard → Settings → API Keys
SKILLJAR_API_KEY=your_api_key_here

# ──────────────────────────────────────────────
# REQUIRED (standalone CLI only — NOT needed for MCP server)
# ──────────────────────────────────────────────

# Anthropic API key — powers the LLM call in CLI mode.
# Not needed when running as MCP server from Claude Code / Cursor.
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────
# OPTIONAL (sensible defaults built in)
# ──────────────────────────────────────────────

# SkillJar API domain (only change if you're on a custom/EU instance)
# SKILLJAR_DOMAIN=api.skilljar.com

# Cache TTL for course catalog listings (seconds). Default: 3600 (1 hour).
# Set to 0 to disable caching.
# CACHE_TTL_SECONDS=3600
